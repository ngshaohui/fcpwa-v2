{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": [".venv", "node_modules"],
  "sortImports": {
    "groups": [
      "builtin",
      "external",
      ["internal", "subpath"],
      ["parent", "sibling", "index"],
      "style",
      "unknown"
    ],
    "internalPattern": ["@/"],
    "newlinesBetween": true,
    "order": "asc"
  }
}
